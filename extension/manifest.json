{
  "manifest_version": 3,
  "name": "Context Keeper",
  "version": "0.9.3",
  "description": "AI 대화 맥락 자동 요약·저장 (modular)",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "https://www.genspark.ai/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.genspark.ai/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "config.js",
        "dom-parser.js",
        "ollama.js",
        "api.js",
        "summarizer.js",
        "ui.js",
        "observer.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}